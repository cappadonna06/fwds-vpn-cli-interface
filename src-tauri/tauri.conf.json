{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "FWDS Controller Console",
  "version": "0.1.1",
  "identifier": "com.frontlinewildfire.controller-console",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "FWDS Controller Console",
        "width": 1280,
        "height": 820,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
"bundle": {
  "active": true,
  "targets": "all",
  "icon": [
    "icons/32x32.png",
    "icons/128x128.png",
    "icons/icon.png",
    "icons/icon.icns",
    "icons/icon.ico"
  ]
}
    ]
  }
}
