{
  "$schema": "../node_modules/@tauri-apps/cli/schema/acl/capability.json",
  "identifier": "default",
  "description": "Default capabilities for the FWDS Controller Console",
  "windows": ["main", "controller-terminal"],
  "permissions": [
    "core:default",
    "core:window:allow-create",
    "core:window:allow-get-all-windows",
    "core:webview:allow-create-webview-window",
    "dialog:default",
    "opener:default"
  ]
}
